{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "mcp": {
    "engram": {
      "command": [
        "/var/home/linuxbrew/.linuxbrew/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "cocoindex-code": {
      "type": "local",
      "enabled": true,
      "command": [
        "ccc",
        "mcp"
      ]
    }
  },
  "provider": {
    "llama.cpp": {
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "ornith-35b": {
          "name": "Ornith 35B"
        },
        "gemma-4-12b": {
          "name": "Gemma 4 12B"
        },
        "gemma-4-e4b": {
          "name": "Gemma 4 E4B"
        }
      }
    }
  }
}
